# Relayer Configuration

# Node Group Private Key (the account that will relay transactions)
# This account must have the NODEGROUP_ROLE role on all CrossHop contracts
RELAYER_PRIVATE_KEY=cf37a01a428dcc6c9df0fcfe88815426233601827f77473bedb4af2df27b50ec

# RPC Endpoints for each network
SEPOLIA_API=https://rpc.sepolia.org
ARBI_SEPOLIA_API=https://sepolia-rollup.arbitrum.io/rpc
OPTI_SEPOLIA_API=https://sepolia.optimism.io
AMOY_API=https://rpc-amoy.polygon.technology
BNBTESTNET_API=https://data-seed-prebsc-1-b.binance.org:8545
FANTOMTESTNET_API=https://rpc.testnet.fantom.network

# CrossHop Contract Addresses on each network
SEPOLIA_CROSSHOP_ADDRESS=
ARBI_SEPOLIA_CROSSHOP_ADDRESS=
OPTI_SEPOLIA_CROSSHOP_ADDRESS=
AMOY_CROSSHOP_ADDRESS=
BNBTESTNET_CROSSHOP_ADDRESS=
FANTOMTESTNET_CROSSHOP_ADDRESS=

# Relayer Configuration
# Gas price multiplier (1.0 = normal price, 1.5 = 50% faster)
GAS_MULTIPLIER=1.2

# Maximum retry attempts for failed transactions
MAX_RETRIES=3

# Retry delay in milliseconds
RETRY_DELAY=5000

# Poll interval for checking new events (milliseconds)
POLL_INTERVAL=12000

# Fee percentage taken by relayer (in basis points, e.g., 10 = 0.1%)
FEE_PERCENTAGE=10

# Batch size for relay operations
BATCH_SIZE=5

# Database path for tracking processed transactions
DB_PATH=./relayer/data/processed.json

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# Log file path
LOG_FILE=./relayer/logs/relayer.log
